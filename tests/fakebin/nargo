#!/usr/bin/env python3
"""Fake `nargo` for tests: emulates compile/execute/check file side-effects."""
import gzip
import hashlib
import re
import sys
from pathlib import Path

ARGS = sys.argv[1:]


def fail(msg, code=1):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(code)


def pkg_name():
    manifest = Path("Nargo.toml")
    if not manifest.is_file():
        fail("Cannot find Nargo.toml")
    m = re.search(r'name\s*=\s*"([^"]+)"', manifest.read_text())
    if not m:
        fail("Nargo.toml missing package name")
    return m.group(1)


def do_compile():
    name = pkg_name()
    src = Path("src/main.nr")
    code = src.read_text() if src.is_file() else ""
    target = Path("target")
    target.mkdir(exist_ok=True)
    bytecode = hashlib.sha256(("bytecode:" + name + code).encode()).hexdigest()
    (target / f"{name}.json").write_text(
        '{"noir_version": "1.0.0-fake", "abi": {}, "bytecode": "%s"}' % bytecode
    )
    print(f"[{name}] Compiled")
    return name


def positional_and_flags(args):
    """Split into positionals and a flag->value map (best effort)."""
    pos, flags, i = [], {}, 0
    while i < len(args):
        a = args[i]
        if a.startswith("-"):
            if i + 1 < len(args) and not args[i + 1].startswith("-"):
                flags[a] = args[i + 1]
                i += 2
            else:
                flags[a] = True
                i += 1
        else:
            pos.append(a)
            i += 1
    return pos, flags


def main():
    if not ARGS or ARGS[0] in ("--version", "-V"):
        print("nargo version = 1.0.0-beta.19")
        print("noirc version = 1.0.0-beta.19+fake")
        return
    cmd, rest = ARGS[0], ARGS[1:]
    if cmd == "check":
        pkg_name()
        p = Path("Prover.toml")
        if not p.is_file() or "--overwrite" in rest:
            p.write_text("# generated by fake nargo\n")
        print("[fake] check ok")
    elif cmd == "compile":
        do_compile()
    elif cmd == "execute":
        name = do_compile()
        pos, flags = positional_and_flags(rest)
        witness = pos[0] if pos else name
        prover = flags.get("--prover-name") or flags.get("-p") or "Prover"
        prover_file = Path(f"{prover}.toml")
        if not prover_file.is_file():
            fail(f"could not find prover file {prover_file}")
        payload = (name + "::").encode() + prover_file.read_bytes()
        with gzip.open(Path("target") / f"{witness}.gz", "wb") as fh:
            fh.write(payload)
        print(f"[{name}] Circuit witness successfully solved")
        print(f"[{name}] Circuit output: Field(0x09)")
    elif cmd == "test":
        print(f"[{pkg_name()}] All tests passed")
    elif cmd == "new":
        pos, flags = positional_and_flags(rest)
        root = Path(pos[0])
        (root / "src").mkdir(parents=True, exist_ok=True)
        nm = flags.get("--name") or root.name
        (root / "Nargo.toml").write_text(
            f'[package]\nname = "{nm}"\ntype = "bin"\n\n[dependencies]\n'
        )
        (root / "src/main.nr").write_text("fn main(x: Field, y: pub Field) { assert(x != y); }\n")
    else:
        fail(f"unknown command {cmd}")


if __name__ == "__main__":
    main()
